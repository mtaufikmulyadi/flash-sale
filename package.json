{
  "name": "flash-sale",
  "version": "1.0.0",
  "description": "High-throughput flash sale system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.ts",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:stress": "ts-node --project tsconfig.json tests/stress/purchaseLoad.ts"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "jsonwebtoken": "^9.0.2",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.11"
  }
}
